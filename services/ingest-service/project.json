{
  "name": "ingest-service",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "tags": ["scope:service", "lang:go"],
  "implicitDependencies": ["models-go", "common-go"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "dependsOn": ["^build"],
      "options": {
        "command": "go build -o dist/ingest-service ./cmd/server",
        "cwd": "services/ingest-service"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": { "command": "go test ./...", "cwd": "services/ingest-service" }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": { "command": "go vet ./...", "cwd": "services/ingest-service" }
    },
    "serve": {
      "executor": "nx:run-commands",
      "options": { "command": "go run ./cmd/server", "cwd": "services/ingest-service" }
    },
    "container": {
      "executor": "nx:run-commands",
      "options": {
        "command": "docker build -f services/ingest-service/Dockerfile -t greenhouse/ingest-service .",
        "cwd": "{workspaceRoot}"
      }
    }
  }
}
