{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "declaration": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@greenhouse/models": ["libs/models-ts/src/index.ts"],
      "@greenhouse/common": ["libs/common-ts/src/index.ts"],
      "@greenhouse/ui": ["libs/ui/src/index.ts"]
    }
  },
  "exclude": ["node_modules", "dist", ".next"]
}
