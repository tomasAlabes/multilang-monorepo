go 1.25.0

// Go workspace: unifies the modules for one-shot `go build ./...` from the
// repo root and for IDE cross-module navigation. Each service's go.mod also
// carries replace directives so it builds standalone in CI and Docker.
use (
	./libs/common-go
	./libs/models-go
	./services/api-gateway
	./services/ingest-service
)
