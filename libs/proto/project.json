{
  "name": "proto",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "library",
  "tags": ["scope:contracts", "lang:proto"],
  "targets": {
    "lint": {
      "executor": "nx:run-commands",
      "options": { "command": "buf lint", "cwd": "{workspaceRoot}" }
    },
    "format": {
      "executor": "nx:run-commands",
      "options": { "command": "buf format -w", "cwd": "{workspaceRoot}" }
    },
    "breaking": {
      "executor": "nx:run-commands",
      "options": {
        "command": "buf breaking --against '.git#branch=main'",
        "cwd": "{workspaceRoot}"
      }
    },
    "codegen": {
      "executor": "nx:run-commands",
      "outputs": [
        "{workspaceRoot}/libs/models-go/gen",
        "{workspaceRoot}/libs/models-ts/src/gen",
        "{workspaceRoot}/libs/models-py/src/greenhouse"
      ],
      "options": { "command": "buf generate", "cwd": "{workspaceRoot}" }
    }
  }
}
