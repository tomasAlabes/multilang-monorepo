{
  "name": "models-go",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "library",
  "tags": ["scope:models", "lang:go"],
  "implicitDependencies": ["proto"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "dependsOn": ["proto:codegen"],
      "options": { "command": "go build ./...", "cwd": "libs/models-go" }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": { "command": "go test ./...", "cwd": "libs/models-go" }
    }
  }
}
