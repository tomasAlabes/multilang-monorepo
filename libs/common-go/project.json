{
  "name": "common-go",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "library",
  "tags": ["scope:shared", "lang:go"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": { "command": "go build ./...", "cwd": "libs/common-go" }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": { "command": "go test ./...", "cwd": "libs/common-go" }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": { "command": "go vet ./...", "cwd": "libs/common-go" }
    }
  }
}
